# React Frontend Environment Configuration
# Copy this to .env and fill in your values

# Backend API Port (for development)
REACT_APP_PORT=5001

# Backend API URL
# For local development:
REACT_APP_API_URL=http://localhost:5001

# For production, use your backend domain:
# REACT_APP_API_URL=https://api.skillswap-plus.com

# Optional: Environment type
REACT_APP_ENV=development
