# Server
NODE_ENV=development
PORT=5001

# Database
MONGODB_URI=mongodb://localhost:27017/skillswap-plus

# Auth
JWT_SECRET=change_me
JWT_EXPIRE=7d

# Client
CLIENT_URL=http://localhost:3000

# PayHere (Sandbox)
# Use PAYHERE_MERCHANT_SECRET for the raw secret, OR use PAYHERE_MERCHANT_SECRET_B64 if you only have it base64-encoded.
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_MERCHANT_SECRET_B64=
PAYHERE_CHECKOUT_URL=https://sandbox.payhere.lk/pay/checkout
PAYHERE_CURRENCY=LKR

# AI (optional)
GEMINI_API_KEY=
